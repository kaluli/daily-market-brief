# Base de datos (por defecto ya usado por la API si no se define)
# DATABASE_URL=postgres://marketbrief:marketbrief_secret@localhost:5432/marketbrief?sslmode=disable

# API (solo si corrés la API en otro host/puerto)
# PORT=3090
# SUMMARIES_PATH=./summaries

# Ingesta: fuentes que requieren API key (opcional; RSS como CNBC no requiere key)
# NEWSAPI_KEY=
# FINNHUB_API_KEY=

# Investment analyst: leave OPENAI_API_KEY unset to avoid costs (stub analyst used, no API calls).
# Set only if you want real LLM analysis (OpenAI charges apply).
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Web: URL de la API (solo necesario si la API no está en localhost:3090)
# NEXT_PUBLIC_API_URL=http://localhost:3090
